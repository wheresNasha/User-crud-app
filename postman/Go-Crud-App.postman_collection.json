{
  "info": {
    "_postman_id": "94439c81-ccf6-4409-9a27-df4c0783f5ed",
    "name": "Go-Crud-App",
    "description": "This collection contains requests for testing and exploring a local Go-based CRUD API for user management. It covers the full set of core operations on the `/users` resource, including creating users, retrieving all users or a user by ID, updating user data with PUT and PATCH, deleting users, and checking resource existence with HEAD.\n\nThe collection also includes search and filtering requests that demonstrate query parameter handling, such as searching users by name, minimum age, or a combination of both. In addition, it contains an OPTIONS request for examining supported operations on a separate endpoint.\n\nOverall, this collection is useful for validating REST behavior, CRUD workflows, partial updates, query parameter scenarios, and endpoint support in a local development environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "52874820",
    "_collection_link": "https://go.postman.co/collection/52874820-94439c81-ccf6-4409-9a27-df4c0783f5ed?source=collection_link"
  },
